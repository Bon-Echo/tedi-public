# Application
APP_NAME=tedi-public
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
PUBLIC_BASE_URL=https://tedi-public.bonecho.ai

# Database
DATABASE_URL=postgresql+asyncpg://tedi:password@localhost:5432/tedi_public
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Session management
DAILY_SESSION_CAP=30
SESSION_TIMEOUT_SECONDS=1500

# Rate limiting
SIGNUP_RATE_LIMIT=5/minute

# CORS (public Tedi origins)
CORS_ORIGINS=https://bonecho.ai,http://localhost:3000

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=ZoiZ8fuDWInAcwPXaVeq
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# AWS
AWS_REGION=us-east-1
S3_BUCKET_NAME=tedi-artifacts

# SES
SES_FROM_EMAIL=tedi@bonecho.ai
SES_REGION=us-east-1
OUTPUT_RECIPIENTS=labeeb@bonecho.ai,deep@bonecho.ai,sifat@bonecho.ai
FOLLOWUP_FROM_EMAIL=sifat@bonecho.ai

# Slack (leave SLACK_WEBHOOK_URL empty to disable Slack notifications)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#board-room

# Admin dashboard / Google SSO
# Only Google accounts whose verified email ends in this domain are admitted.
ADMIN_ALLOWED_DOMAIN=bonecho.ai
# Required in production: 32+ char random string. The placeholder below is
# accepted in dev/local only — APP_ENV=production refuses to boot with it.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_SESSION_SECRET=dev-only-change-me-in-production-32+chars
ADMIN_SESSION_TTL_SECONDS=43200
# Origin of the deployed admin dashboard (frontend). Restrict admin CORS to this.
ADMIN_UI_ORIGIN=http://localhost:3001

# Google OAuth client credentials (Web application).
# Create at https://console.cloud.google.com/apis/credentials -> "Create OAuth
# client ID" -> "Web application", and add the redirect URI below to the
# client's "Authorized redirect URIs" list.
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
# Must exactly match a redirect URI configured on the Google OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
